PORT=3000
# Produção (Railway): use senha longa; opcional ENFORCE_STRONG_ADMIN_SENHA=true
ADMIN_SENHA=defina_uma_senha_forte
ADMIN_SENHA_MIN_LENGTH=12
# ENFORCE_STRONG_ADMIN_SENHA=true

PUBLIC_URL=
PUBLIC_BASE_URL=

# Em produção no Railway: monte Volume em /data. Sem DB_PATH explícito no Railway → /data/database.sqlite
DB_PATH=
# REQUIRE_PERSISTENT_DB=true

# No Railway o import ao subir fica DESLIGADO por padrão. Primeira carga: rode import manual ou defina uma vez:
# AUTO_IMPORT_ON_START=true
# Localmente continua ligado se não definir "false".
AUTO_IMPORT_ON_START=

IMPORT_DEFAULT_SENHA=mudar123
# SECRETARIA_TOKEN_SALT=
# COMPUTADORES_XLSX=
# MONITORES_XLSX=

# Anti-força bruta (opcional)
# LOGIN_FAIL_MAX=30
# LOGIN_FAIL_WINDOW_MS=900000
# ADMIN_FAIL_MAX=40
# ADMIN_FAIL_WINDOW_MS=900000

# Export Excel: máximo de linhas (proteção de memória)
# EXPORT_MAX_ROWS=100000
