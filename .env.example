PORT=3000
ADMIN_SENHA=defina_uma_senha_forte
# URL pública (qualquer um): PUBLIC_URL, PUBLIC_BASE_URL, APP_URL, BASE_URL
# Ou Railway define RAILWAY_PUBLIC_DOMAIN — também é detectado.
PUBLIC_URL=
PUBLIC_BASE_URL=
DB_PATH=
# Importa computadores.xlsx e monitores.xlsx ao subir se o banco não tiver PCs. Desligue: AUTO_IMPORT_ON_START=false
AUTO_IMPORT_ON_START=
# Senha inicial de cada secretaria nova no import (defina no Railway — igual em todo deploy).
IMPORT_DEFAULT_SENHA=mudar123
# Opcional: mistura secreta estável; se definir, inclua o mesmo valor no Railway sempre (muda o sufixo do token).
# SECRETARIA_TOKEN_SALT=
# Caminhos opcionais para o import (padrão: raiz do projeto)
# COMPUTADORES_XLSX=
# MONITORES_XLSX=
